# Appliance OS 5-partition A/B layout for eMMC (mmcblk0)
#
# p1  /boot  vfat  128M   RPi firmware + U-Boot + config.txt + boot.scr + DTBs
# p2  /      ext4  auto   rootfs slot A (read-only)
# p3  /      ext4  auto   rootfs slot B (read-only, same size as A)
# p4  /data  ext4  1G     persistent platform + app data
# p5  /home  ext4  500M   user home dirs (growfs to fill remaining eMMC)

part /boot --source bootimg-partition --ondisk mmcblk0 --fstype=vfat --label boot --active --align 4096 --size 128
part / --source rootfs --ondisk mmcblk0 --fstype=ext4 --label rootfs_A --align 4096
part / --source rootfs --ondisk mmcblk0 --fstype=ext4 --label rootfs_B --align 4096
part /data --fixed-size 1024M --ondisk mmcblk0 --fstype=ext4 --label data --align 4096
part /home --source rootfs --rootfs-dir=${IMAGE_ROOTFS}/home --ondisk mmcblk0 --fstype=ext4 --label homefs --align 4096 --size 500 --fsoptions "x-systemd.growfs"
