# Yocto build artifacts (build/Dockerfile is tracked; ignore everything else under build/)
build/conf/
build/tmp/
build/tmp-*/
build/cache/
build/downloads/
build/sstate-cache/
build/bitbake-cookerdaemon.log
build/bitbake.lock
build-*/
tmp-*/
sstate-cache/

# Yocto downloads and sstate (bind-mounted from host cache)
/downloads/
/sstate-cache/

# kas repo reference cache (bind-mounted from host cache)
/repos/

# kas state
.kas-cache/

# kas-managed upstream layer checkouts (cloned by kas into build/repos/)
# Only our custom layers (under layers/) are tracked in this repo.
/build/repos/

# Podman / Docker
*.tar
docker-compose.override.yml

# Build artifacts extracted from container
/artifacts/

# Editor cruft
.idea/
.vscode/
*.swp
*.swo
*~
\#*\#

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Python (kas may leave these)
__pycache__/
*.pyc

# Local build cache (downloads, sstate, repo refs, podman auth)
/.cache/

# User-local config overrides (secrets, wpa_supplicant.conf, etc.)
/local/

# Crush / agent tooling (keep .agents/ tracked, ignore tool state)
.crush/
