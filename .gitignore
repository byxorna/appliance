# Yocto build artifacts (build/Dockerfile is tracked; ignore everything else under build/)
build/*
!build/Dockerfile
build-*/
tmp-*/
sstate-cache/

# Yocto downloads and sstate (bind-mounted from host cache)
/downloads/
/sstate-cache/

# kas repo reference cache (bind-mounted from host cache)
/repos/

# kas state
.kas-cache/
.kas_shell_history

# Podman / Docker
*.tar
docker-compose.override.yml

# Build artifacts extracted from container
/artifacts/

# Editor cruft
.idea/
.vscode/
*.swp
*.swo
*~
\#*\#

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Python (kas may leave these)
__pycache__/
*.pyc

# Local build cache (downloads, sstate, repo refs, podman auth)
/.cache/

# User-local config overrides (secrets, wpa_supplicant.conf, etc.)
/local/

# Crush / agent tooling (keep .agents/ tracked, ignore tool state)
.crush/
