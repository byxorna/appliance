# Yocto build artifacts (build/Dockerfile is tracked; ignore everything else under build/)
build/conf/
build/tmp/
build/tmp-*/
build/cache/
build/downloads/
build/sstate-cache/
build/bitbake-cookerdaemon.log
build/bitbake.lock
build-*/
tmp-*/
sstate-cache/

# Yocto downloads and sstate (bind-mounted from host cache)
/downloads/
/sstate-cache/

# kas repo reference cache (bind-mounted from host cache)
/repos/

# kas state
.kas-cache/

# kas-managed upstream layer checkouts (cloned by kas at build time)
# Only our custom meta-kiosk-* layers are tracked in this repo.
/poky/
/meta-openembedded/
/meta-raspberrypi/
/meta-seeed-cm4/
/meta-clang/
/meta-browser/
/meta-rauc/
/meta-rauc-community/
/meta-lts-mixins-rust/
/meta-lts-mixins-uboot/

# Podman / Docker
*.tar
docker-compose.override.yml

# Editor cruft
.idea/
.vscode/
*.swp
*.swo
*~
\#*\#

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Python (kas may leave these)
__pycache__/
*.pyc

# Crush / agent tooling (keep .agents/ tracked, ignore tool state)
.crush/
