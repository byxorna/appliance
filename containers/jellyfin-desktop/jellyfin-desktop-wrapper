#!/bin/sh
# Wrapper script for Jellyfin Desktop inside the appliance container.
# Delegates to the extracted AppImage's AppRun, which sets up the
# bundled glibc, ELF interpreter symlink, LD_LIBRARY_PATH, and
# PipeWire paths.
#
# LD_LIBRARY_PATH is NOT set here because it would poison host
# binaries (bash, coreutils) that AppRun invokes before exec'ing
# jellyfin-desktop. AppRun sets it right before the final exec.

set -e

LOG_LEVEL="${JFN_LOG_LEVEL:-info}"

exec /opt/jellyfin-desktop/AppRun --log-level "$LOG_LEVEL" --platform-paint shm "$@"
