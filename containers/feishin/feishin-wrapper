#!/bin/sh
# Wrapper script for Feishin Electron app inside the appliance container.
# Ensures Wayland backend and correct runtime paths.

set -e

FEISHIN_DIR=/opt/feishin

# The extracted AppImage bundles its own copies of some shared libraries
# alongside the main binary. Point the linker at the install directory
# so Electron finds them.
export LD_LIBRARY_PATH="$FEISHIN_DIR${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

# Electron/Chromium Wayland flags
ELECTRON_FLAGS="--ozone-platform=wayland --enable-features=UseOzonePlatform"

# Disable GPU sandbox (the container runs as an unprivileged user —
# the sandbox tries to clone namespaces that need CAP_SYS_ADMIN).
ELECTRON_FLAGS="$ELECTRON_FLAGS --no-sandbox"

exec "$FEISHIN_DIR/feishin" $ELECTRON_FLAGS "$@"
